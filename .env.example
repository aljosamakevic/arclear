# RPC for Arc Testnet (chain id 5042002).
# Public default below; swap in your own provider endpoint if you have one.
ARC_RPC_URL=https://rpc.testnet.arc.network

# Deployer private key (0x-prefixed). Needs native USDC for gas AND ERC-20 USDC
# for collateral — both from https://faucet.circle.com/ (select Arc Testnet).
DEPLOYER_PK=

# Mnemonic used to derive the 5 demo agent accounts (any BIP-39 phrase).
AGENT_MNEMONIC=

# Filled in after `forge script` deploys (see README):
HUB_USDC=
HUB_EURC=

# V2 hubs (threshold-consent protocol). v1 hubs above stay live as Arclear Net v1.
HUB_V2_USDC=
HUB_V2_EURC=
