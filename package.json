{
  "name": "arclear",
  "version": "0.1.0",
  "description": "Obligation-netting clearinghouse primitive for Arc — 100 micropayments, 1 settlement.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:contracts": "cd contracts && forge test -vvv",
    "fixture": "tsx test/genFixture.ts",
    "abi": "cp contracts/out/ClearingHub.sol/ClearingHub.json src/abi/ClearingHub.json",
    "e2e:anvil": "tsx demo/e2e.ts --anvil",
    "e2e:testnet": "tsx demo/e2e.ts",
    "demo": "tsx demo/server.ts",
    "report": "tsx demo/report.ts",
    "sweep": "tsx demo/sweep.ts"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^3.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
